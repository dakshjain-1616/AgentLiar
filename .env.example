# AgentLiar Detector - Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter Configuration (Required for LLM Judge)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text

# Verification Weights (optional - defaults to 0.25 each)
# FILE_CHECK_WEIGHT=0.25
# TEST_CHECK_WEIGHT=0.25
# SCOPE_CHECK_WEIGHT=0.25
# LLM_JUDGE_WEIGHT=0.25

# Confidence Threshold (optional - default is 70.0)
# CONFIDENCE_THRESHOLD=70.0
